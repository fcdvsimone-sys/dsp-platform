generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Driver {
  id             String   @id @default(cuid())
  employeeId     String   @unique  // Amazon TransporterID
  firstName      String
  lastName       String
  phone          String?           // personal phone
  workPhone      String?
  email          String?
  status         String   @default("active") // active, inactive, terminated
  qualifications String?           // CDV, EDV, Step Van, etc.
  idExpiration   DateTime?
  hireDate       DateTime?
  terminatedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scorecards    Scorecard[]
  coachings     Coaching[]
}

model Scorecard {
  id                    String   @id @default(cuid())
  driverId              String
  weekOf                DateTime

  overallStanding       String?  // Platinum, Gold, Silver, Bronze, Below Standard
  overallScore          Float?   // Numeric composite score (e.g. 98.38)

  // Safety metrics — rate per trip (lower is better)
  speedingRate          Float?   // Speeding Event Rate (per trip)
  seatbeltRate          Float?   // Seatbelt-Off Rate (per trip)
  distractionRate       Float?   // Distractions Rate (per trip)
  signalViolationRate   Float?   // Sign/Signal Violations Rate (per trip)
  followingDistanceRate Float?   // Following Distance Rate (per trip)

  // Delivery metrics
  cdfDpmo               Int?     // Contact Delivery Failure DPMO
  ced                   Float?   // Customer Experience Defect
  dcr                   Float?   // Delivery Completion Rate %
  dsb                   Float?   // DSB
  pod                   Float?   // Photo on Delivery %
  psb                   Float?   // PSB
  packagesDelivered     Int?

  fico                  Float?   // FICO (may be empty in driver-level export)

  createdAt             DateTime @default(now())

  driver                Driver   @relation(fields: [driverId], references: [id])

  @@unique([driverId, weekOf])
}

model Coaching {
  id            String   @id @default(cuid())
  driverId      String
  type          String   // verbal, written, final, termination
  category      String   // scorecard, attendance, conduct, safety, other
  description   String
  actionPlan    String?
  conductedBy   String
  conductedAt   DateTime @default(now())
  signedAt      DateTime?
  signatureUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driver        Driver   @relation(fields: [driverId], references: [id])
}
